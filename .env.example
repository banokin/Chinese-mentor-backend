ASR_BACKEND=huggingface_inference
HF_WHISPER_MODEL=openai/whisper-large-v3
# Язык вывода Whisper (ISO 639-1): zh — 汉字; не оставляйте пустым.
HF_ASR_LANGUAGE=zh
OPENAI_API_KEY=
OPENAI_TRANSCRIPTION_MODEL=whisper-1
# Озвучка эталона на странице практики (Speech API)
OPENAI_TTS_MODEL=tts-1
OPENAI_TTS_VOICE=nova
OPENAI_CHAT_MODEL=gpt-4o-mini
HF_TOKEN=

# LangSmith — трейсы LangChain/LangGraph (https://smith.langchain.com)
# Включите: LANGCHAIN_TRACING_V2=true и ключ (ниже — LANGCHAIN_API_KEY или LANGSMITH_API_KEY)
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
# LANGSMITH_API_KEY=   # то же, что LANGCHAIN_API_KEY, в документации Smith часто так
LANGCHAIN_PROJECT=chinese-pronunciation-trainer
# LANGCHAIN_ENDPOINT=https://api.smith.langchain.com

# Langfuse — трейсы LangChain/LangGraph (https://langfuse.com), callback в /api/agent и /api/langgraph
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
# LANGFUSE_HOST=https://cloud.langfuse.com

# Qdrant (HTTP API): Cloud https://xxx.cloud.qdrant.io:6333 или http://localhost:6333
QDRANT_URL=
QDRANT_API_KEY=
QDRANT_COLLECTION=chinese_lexicon
# QDRANT_VECTOR_NAME=
# Текст чанка в payload (как при загрузке через LangChain QdrantVectorStore)
# QDRANT_CONTENT_PAYLOAD_KEY=page_content
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# RAG_TOP_K=5
